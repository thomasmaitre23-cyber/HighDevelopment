<%- include('partials/header') %><section class="panel"><h1>Tableau de bord</h1><div class="profile"><img src="<%= user.avatar %>"><div><h2><%= user.username %></h2><p><%= user.email %> • <span class="badge"><%= user.role %></span></p></div></div><div class="two"><form method="post" action="/profile" enctype="multipart/form-data" class="box"><h3>Modifier le profil</h3><input name="username" value="<%= user.username %>" placeholder="Pseudo"><input type="file" name="avatar"><button class="btn">Sauvegarder</button></form><form method="post" action="/password" class="box"><h3>Changer le mot de passe</h3><input type="password" name="new_password" placeholder="Nouveau mot de passe"><button class="btn">Changer</button></form></div><h2>Historique des connexions</h2><table><tr><th>Date</th><th>IP</th></tr><% history.forEach(h=>{ %><tr><td><%= h.date %></td><td><%= h.ip %></td></tr><% }) %></table></section><%- include('partials/footer') %>
