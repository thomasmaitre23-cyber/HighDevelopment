<%- include('../partials/header') %><section class="panel"><h1>Utilisateurs</h1><table><tr><th>ID</th><th>Email</th><th>Pseudo</th><th>Rôle</th><th>Actions</th></tr><% users.forEach(u=>{ %><tr><td><%= u.id %></td><td><%= u.email %></td><td><%= u.username %></td><td><%= u.role %></td><td><% if(canManage){ %><form method="post" action="/staff/users/<%= u.id %>/role" class="miniForm"><select name="role"><option>Membre</option><option>Modo</option><option>Admin</option><option>Owner</option></select><button>Changer</button></form><% } %><% if(canBan){ %><form method="post" action="/staff/users/<%= u.id %>/ban" class="miniForm"><button>Ban</button></form><% } %></td></tr><% }) %></table></section><%- include('../partials/footer') %>
