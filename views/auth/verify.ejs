<%- include('../partials/header') %>
<section class="auth">
  <div class="panel">
    <h1>Vérification A2F</h1>
    <p>Un code à 6 chiffres a été envoyé à <b><%= email %></b>.</p>
    <% if(error){ %><p class="err"><%= error %></p><% } %>
    <% if(success){ %><p style="color:#22c55e"><%= success %></p><% } %>
    <form method="POST" action="/verify">
      <input name="code" inputmode="numeric" maxlength="6" placeholder="Code à 6 chiffres" required autofocus>
      <button class="btn" type="submit">Valider la connexion</button>
    </form>
    <form method="POST" action="/verify/resend" style="margin-top:12px">
      <button class="btn small" type="submit">Renvoyer un code</button>
    </form>
    <p>Le code expire après 5 minutes.</p>
  </div>
</section>
<%- include('../partials/footer') %>
