<%- include('partials/header') %><section class="title"><h1>🛒 Boutique</h1><p>PayPal et Paysafecard acceptés. Pour payer, passe commande puis ouvre un ticket.</p></section><section class="products"><% products.forEach(p=>{ %><div class="product"><img src="<%= p.image %>"><h2><%= p.name %></h2><p><%= p.description %></p><b><%= p.price %></b><% if(user){ %><form method="post" action="/order/<%= p.id %>"><button class="btn">Commander</button></form><% } else { %><a class="btn" href="/login">Se connecter pour commander</a><% } %></div><% }) %></section><%- include('partials/footer') %>
