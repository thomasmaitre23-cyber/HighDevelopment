<%- include('../partials/header') %><section class="panel"><h1>💬 Tickets</h1><form method="post" action="/tickets" class="inline"><input name="subject" placeholder="Sujet du ticket" required><button class="btn">Ouvrir un ticket</button></form><div class="tickets"><% tickets.forEach(t=>{ %><a class="ticket" href="/tickets/<%= t.id %>"><b>#<%= t.id %> — <%= t.subject %></b><span><%= t.status %></span><small><%= t.email || '' %> <%= t.updated_at %></small></a><% }) %></div></section><%- include('../partials/footer') %>
